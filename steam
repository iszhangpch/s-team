#!/usr/bin/env bash
# steam — launch Claude Code with agent teams in a target project
# Usage: ./steam [project-path]
#        Defaults to current directory if no path given.

set -euo pipefail

if ! command -v mt &>/dev/null; then
  echo "Error: mt CLI is required. Install Claude Code via mt."
  exit 1
fi

if ! command -v tmux &>/dev/null; then
  echo "Error: tmux is required. Install: brew install tmux"
  exit 1
fi

PROJECT="${1:-$PWD}"

if [[ ! -d "$PROJECT" ]]; then
  echo "Error: project directory '$PROJECT' does not exist."
  exit 1
fi

PROJECT="$(cd "$PROJECT" && pwd)"

# Verify agent teams is enabled in the project settings.
SETTINGS="$PROJECT/.claude/settings.json"
if [[ ! -f "$SETTINGS" ]] || ! python3 -c "import json,sys; d=json.load(open('$SETTINGS')); sys.exit(0 if d.get('env',{}).get('CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS')=='1' else 1)" 2>/dev/null; then
  echo "Error: agent teams not enabled in $SETTINGS"
  echo "Run install.sh first: ./install.sh $PROJECT"
  exit 1
fi

# Agent teams requires a tmux session for split-pane display.
if [[ -z "${TMUX:-}" ]]; then
  SESSION="steam-$$"
  SCRIPT="$(realpath "$0")"
  exec tmux new-session -s "$SESSION" "$SCRIPT" "$PROJECT"
fi

cd "$PROJECT"
exec mt --code
