#!/usr/bin/env bash
# s-team — launch Claude Code with agent teams and tmux split-pane support
# Usage: ./s-team

set -euo pipefail

if ! command -v claude &>/dev/null; then
  echo "Error: claude CLI is required. Install Claude Code."
  exit 1
fi

# Agent teams requires a tmux session for split-pane display.
if [[ -z "${TMUX:-}" ]]; then
  if ! command -v tmux &>/dev/null; then
    echo "Error: tmux is required. Install: brew install tmux"
    exit 1
  fi
  SESSION="s-team-$$"
  SCRIPT="$(realpath "$0")"
  exec tmux new-session -s "$SESSION" "$SCRIPT"
fi

exec claude
