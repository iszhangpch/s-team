#!/usr/bin/env bash
# s-team — coding team entry point
# Usage:
#   ./s-team "<task description>"
#   ./s-team resume --from <clarifier|planner|generator>
#
# Requires: claude CLI, tmux

set -euo pipefail

usage() {
  echo "Usage:"
  echo "  ./s-team \"<task description>\""
  echo "  ./s-team resume --from <clarifier|planner|generator>"
  exit 1
}

if [[ $# -eq 0 ]]; then
  usage
fi

if ! command -v claude &>/dev/null; then
  echo "Error: claude CLI is required. Install Claude Code."
  exit 1
fi

# Agent teams requires a tmux session for split-pane display.
if [[ -z "${TMUX:-}" ]]; then
  if ! command -v tmux &>/dev/null; then
    echo "Error: tmux is required. Install: brew install tmux"
    exit 1
  fi
  SESSION="s-team-$$"
  SCRIPT="$(realpath "$0")"
  ARGS="$(printf '%q ' "$@")"
  exec tmux new-session -s "$SESSION" "$SCRIPT $ARGS"
fi

if [[ "$1" == "resume" ]]; then
  if [[ "${2:-}" != "--from" ]] || [[ -z "${3:-}" ]]; then
    usage
  fi
  STAGE="$3"
  if [[ "$STAGE" != "clarifier" && "$STAGE" != "planner" && "$STAGE" != "generator" ]]; then
    echo "Error: --from must be one of: clarifier, planner, generator"
    exit 1
  fi
  exec claude "Resume the s-team pipeline from the ${STAGE} stage.

Existing files are in place — read them before spawning teammates:
- .steam/spec.md (if Clarifier already completed)
- .steam/task.md (if Planner already completed)

Spawn Evaluator first if not already running, then spawn the ${STAGE} teammate."
else
  TASK="$1"
  exec claude "/s-team ${TASK}"
fi
