#!/usr/bin/env bash
# s-team — coding team entry point
# Usage:
#   ./s-team "<task description>"
#   ./s-team resume --from <clarifier|planner|generator>
#
# Requires: claude CLI, tmux (for split-pane teammate display)
# Claude Code handles all tmux pane management via agent teams.

set -euo pipefail

usage() {
  echo "Usage:"
  echo "  ./s-team \"<task description>\""
  echo "  ./s-team resume --from <clarifier|planner|generator>"
  exit 1
}

if [[ $# -eq 0 ]]; then
  usage
fi

if ! command -v claude &>/dev/null; then
  echo "Error: claude CLI is required. Install Claude Code."
  exit 1
fi

# Claude Code's tmux split-pane mode requires running inside a tmux session.
# If not already in tmux, create a session and re-launch inside it.
if [[ -z "${TMUX:-}" ]]; then
  if ! command -v tmux &>/dev/null; then
    echo "Error: tmux is required for split-pane mode. Install: brew install tmux"
    exit 1
  fi
  # Re-run this script inside a new tmux session
  SESSION="s-team-$$"
  exec tmux new-session -s "$SESSION" -e "TMUX_SESSION=$SESSION" \
    "$(realpath "$0") $(printf '%q ' "$@")"
fi

if [[ "$1" == "resume" ]]; then
  if [[ "${2:-}" != "--from" ]] || [[ -z "${3:-}" ]]; then
    usage
  fi
  STAGE="$3"
  if [[ "$STAGE" != "clarifier" && "$STAGE" != "planner" && "$STAGE" != "generator" ]]; then
    echo "Error: --from must be one of: clarifier, planner, generator"
    exit 1
  fi
  exec claude --teammate-mode tmux "Resume the s-team pipeline from the ${STAGE} stage.

Existing files are in place — read them before spawning teammates:
- spec.md (if Clarifier already completed)
- task.md (if Planner already completed)

Spawn Evaluator first if not already running, then spawn the ${STAGE} teammate."
else
  TASK="$1"
  exec claude --teammate-mode tmux "Start the s-team coding pipeline for this task: ${TASK}

Follow the pipeline defined in CLAUDE.md."
fi
